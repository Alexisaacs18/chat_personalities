PORT=8787
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=change-me-to-a-long-random-string
# Must match the app bundle ID in the Apple identity token `aud` claim
APPLE_CLIENT_ID=com.personalitychat.app
# Optional: accept multiple bundle IDs (comma-separated), e.g. after a rename
# APPLE_CLIENT_IDS=com.personalitychat.app,com.tonechat.app
ANTHROPIC_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=2048
CHAT_TEMPERATURE=0.7
CHAT_HISTORY_LIMIT=10
# Rolling 4-hour API spend caps (USD, based on actual input/output tokens)
GUEST_BUDGET_USD_4H=0.1
APPLE_BUDGET_USD_4H=0.2
INPUT_USD_PER_MTOK=3
OUTPUT_USD_PER_MTOK=15
# Anti-spam burst limits per minute (high fidelity counts as 2)
GUEST_BURST_PER_MINUTE=5
APPLE_BURST_PER_MINUTE=10
HIGH_FIDELITY_ENABLED=true
HIGH_FIDELITY_APPLE_ONLY=true
# Local only — set false on Vercel production
ALLOW_DEV_AUTH=true
